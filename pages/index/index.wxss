/* ===== 整体容器 ===== */
.container {
  padding: 20rpx 24rpx 40rpx;
  min-height: 100vh;
  background: #f0f4f8;
}

/* ===== 状态卡片 ===== */
.status-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.status-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.status-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.dot-connected {
  background: #34c759;
  box-shadow: 0 0 8rpx #34c759;
}

.dot-disconnected {
  background: #c7c7cc;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1c1e;
}

.device-name {
  display: block;
  font-size: 26rpx;
  color: #3c3c43;
  margin-top: 6rpx;
}

.log-text {
  display: block;
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 8rpx;
  line-height: 1.5;
}

/* ===== 区块标题 ===== */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #636366;
  margin: 20rpx 4rpx 16rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* ===== 蓝牙管理按钮 ===== */
.ble-buttons {
  display: flex;
  gap: 16rpx;
}

.ble-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
  line-height: 1.4;
}

.btn-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.scan-btn {
  background: #1a73e8;
  color: #fff;
}

.stop-btn {
  background: #ff9500;
  color: #fff;
}

.disconnect-btn {
  background: #ff3b30;
  color: #fff;
}

.ble-btn[disabled] {
  opacity: 0.4;
}

/* ===== 设备列表 ===== */
.device-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.device-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f2f2f7;
  transition: background 0.15s;
}

.device-item:last-child {
  border-bottom: none;
}

.device-item.connecting {
  background: #e8f0fe;
}

.device-info {
  flex: 1;
}

.device-item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1c1e;
}

.device-item-id {
  display: block;
  font-size: 22rpx;
  color: #8e8e93;
  margin-top: 4rpx;
}

.device-rssi {
  font-size: 24rpx;
  color: #636366;
}

/* ===== 控制区域 ===== */
.control-area {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.control-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
  justify-content: center;
}

/* 控制按钮通用 */
.ctrl-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 24rpx;
  font-size: 48rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.15);
  transition: transform 0.1s, box-shadow 0.1s;
  letter-spacing: 0;
  padding: 0;
  line-height: 140rpx;
}

.ctrl-btn:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
}

.btn-w { background: #1a73e8; color: #fff; }
.btn-a { background: #34c759; color: #fff; }
.btn-s { background: #ff9500; color: #fff; }
.btn-d { background: #ff3b30; color: #fff; }
.btn-q { background: #af52de; color: #fff; }
.btn-f { background: #00bcd4; color: #fff; }

/* ===== 发送记录 ===== */
.send-log {
  background: #fff;
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  height: 200rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.log-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f2f2f7;
}

.log-char {
  background: #1a73e8;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  text-align: center;
  line-height: 48rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.log-time {
  font-size: 24rpx;
  color: #8e8e93;
}

/* ===== 空状态提示 ===== */
.empty-tip {
  text-align: center;
  color: #8e8e93;
  font-size: 28rpx;
  margin-top: 80rpx;
  padding: 40rpx;
}
